# ShellCheck configuration for this repo.
#
# CI runs `shellcheck -S warning` over every shell script. The codes disabled
# below are pre-existing, advisory-only findings in the legacy day-2 lifecycle
# scripts; they are intentionally suppressed repo-wide so CI stays meaningful
# for new contributions without rewriting working scripts. Remove an entry and
# fix the underlying script when you touch it.
#
#   SC2034 - var set but "appears unused" (set by flag parsing, read elsewhere)
#   SC2043 - single-item for-loop (intentional, keeps a uniform iteration shape)
#   SC2115 - rm "$var"/* destructive-expansion guard (legacy backup pruning)
disable=SC2034,SC2043,SC2115
