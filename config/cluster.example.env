# Copy to config/cluster.env and adjust for your environment.

CLUSTER_NAME=lab
BASE_DOMAIN=ocp.example.com
LOCATION=northeurope

# Private DNS layout for the cluster's API + Ingress records.
#   false (default, recommended): cluster zone is named
#     ${CLUSTER_NAME}.${BASE_DOMAIN}  e.g. "lab.ocp.example.com"
#     Records inside use short names: "api", "api-int", "*.apps"
#     -> FQDNs are api.lab.ocp.example.com etc.
#     This is what openshift-install's ingress-operator (dns-controller)
#     expects so it can write *.apps records on its own (B62 fix).
#   true (legacy): cluster zone is just ${BASE_DOMAIN}
#     ("ocp.example.com") with long record names like "api.lab".
#     FQDNs are the same, but the ingress-operator cannot find its
#     zone object and the install hangs waiting for ClusterOperator
#     ingress=Available. Set this to true ONLY for an existing
#     pre-B62-fix cluster you cannot rebuild — switching layouts
#     destroys + recreates the private DNS zone resource.
USE_LEGACY_DNS_LAYOUT=false

# Cluster CPU architecture. Drives:
#   - OpenShift install-config "architecture" (amd64 vs arm64)
#   - RHCOS stream lookup (x86_64 vs aarch64)
#   - Azure Shared Image Gallery image (x64 vs Arm64)
#   - Uploader VM size + Ubuntu image SKU
#   - Default VM-size families below (D*s_v5 vs D*ps_v5)
# Allowed values: x86_64 (default, most Azure deployments) | arm64
# See CPU-docs/architecture.md for the full mapping table and override knobs.
ARCHITECTURE=x86_64

# Resource group for install-config's baseDomainResourceGroupName. The Azure
# installer requires this field even for publish: Internal. When
# CREATE_PUBLIC_DNS=true this is the RG holding the public parent zone; when
# false (internal-only) point it at an RG with a usable public base-domain zone
# for installer validation only. See docs/dns-internal-only.md.
DNS_RESOURCE_GROUP=rg-dns-public-example
NETWORK_RESOURCE_GROUP=rg-network-example
WORKLOAD_RESOURCE_GROUP=rg-ocp-lab
VIRTUAL_NETWORK=vnet-ocp-example

# ---- Public DNS (opt-in) ---------------------------------------------------
# Default false = internal-only: the repo provisions NO public sub-zone and NO
# NS delegation. The cluster's api / api-int / *.apps records are served by the
# Azure PRIVATE DNS zone (${CLUSTER_NAME}.${BASE_DOMAIN}), VNet-linked and never
# public. Set true only when you want a delegated public sub-zone for the
# OpenShift base domain. See docs/dns-internal-only.md.
CREATE_PUBLIC_DNS=false

# Public parent DNS zone. Only used when CREATE_PUBLIC_DNS=true: the repo creates
# a sub-zone $BASE_DOMAIN under it and writes the NS-record delegation. Ignored
# for internal-only installs.
PARENT_DNS_ZONE=example.com
PARENT_DNS_RESOURCE_GROUP=rg-dns-public-example
# Resource group containing the privatelink.blob.core.windows.net private DNS
# zone (or an empty zone the repo can manage). Often equals
# $NETWORK_RESOURCE_GROUP in single-team setups.
# Only used when MANAGE_STORAGE_PRIVATE_ENDPOINT=true.
HUB_DNS_RESOURCE_GROUP=rg-private-dns-example

# Storage-account Private Endpoint + DNS ownership (default false = centralized).
# When false, the customer's platform team provisions the storage blob Private
# Endpoint and registers its privatelink.blob.core.windows.net A-record and VNet
# link centrally/manually; the repo does NOT create them. Set true only if you
# want the repo to manage the Private Endpoint, A-record, and hub VNet link
# itself (the legacy self-managed behavior). See docs/network-prereqs.md.
MANAGE_STORAGE_PRIVATE_ENDPOINT=false

# Subscription IDs (cross-sub support for DNS zones).
#
# The repo distinguishes three subscription scopes:
#   - CLUSTER_SUBSCRIPTION_ID    : workload VMs, VNet, RG, storage
#                                  (set further down in the day-2 block)
#   - DNS_SUBSCRIPTION_ID        : owner of the public parent DNS zone
#                                  (often a central corp-IT / platform sub)
#   - PRIVATE_DNS_SUBSCRIPTION_ID: owner of privatelink.blob.core.windows.net
#                                  (often co-located with a connectivity
#                                   hub sub, but conceptually separate)
#
# Single-subscription sandbox: set all three to the same UUID.
#
# Connectivity / hub subscription (if you peer to a hub VNet) is NOT a
# separate env var here. It is consumed via subnet ARM IDs in BYO-network
# mode (each /subscriptions/<HUB_UUID>/... subnet ID embeds the hub sub
# UUID). See docs/network-prereqs.md section 6 (VNet peering).
DNS_SUBSCRIPTION_ID=
PRIVATE_DNS_SUBSCRIPTION_ID=

# Public IP (or CIDR) allowed inbound to the uploader VM and to any
# selected jump-host access pattern that permits SSH from your workstation.
# Set to your workstation public IP plus /32. Example: 203.0.113.10/32
# For enterprise tenants this is usually your corporate VPN exit CIDR -
# ask IT. See docs/pre-install-checklist.md row 12.
ADMIN_SSH_SOURCE_IP=203.0.113.10/32

# Optional Windows browser/RDP jump host for internal-console access.
# Not required for install; default false to avoid enterprise Windows-image
# policy failures and idle VM cost. Prefer existing VPN/ExpressRoute,
# Linux jump host, hub-firewall DNAT, or Azure Bastion patterns in
# docs/jump-host-access-decision.md.
CREATE_WINDOWS_JUMP=false

# OpenShift infraID used to name cluster-runtime-aware Azure resources
# (NSGs, route-tables). Defaults to ${CLUSTER_NAME}-poc when render-tfvars
# runs and no install/metadata.json exists yet. After `make ignition` the
# real infraID becomes available; re-run `make tfvars` to pick it up.
INFRA_ID=

CONTROL_PLANE_SUBNET=snet-ocp-master
COMPUTE_SUBNET=snet-ocp-worker

# Per-subnet CIDRs created by terraform/01-network. master/worker/bootstrap sit
# inside MACHINE_NETWORK_CIDR (the OpenShift machineNetwork); multus and the
# optional sriov/CNF subnets are separate secondary ranges in the VNet.
# Defaults below match the upstream tfvars.example. Resize for production.
SUBNET_MASTER_CIDR=10.20.1.0/28
SUBNET_WORKER_CIDR=10.20.1.16/28
SUBNET_BOOTSTRAP_CIDR=10.20.1.32/28
# Multus secondary-network subnet. Default /23 (~500 pod IPs via Whereabouts).
SUBNET_MULTUS_CIDR=10.20.2.0/23

# ---- Optional SR-IOV demo worker (default OFF) -----------------------
# Set ENABLE_SRIOV=true to create the snet-ocp-sriov subnet (01-network) and a
# dedicated SR-IOV demo worker VM (vm-worker-sriov, 8 vCPU, 3 NICs incl. an
# Accelerated-Networking SR-IOV NIC) in 05-workers, for host-device/SR-IOV
# Multus validation. Default false provisions no SR-IOV resources. Independent
# of CNF_PROFILE. SUBNET_SRIOV_CIDR and SRIOV_WORKER_VM_SIZE below are only used
# when ENABLE_SRIOV=true. The SR-IOV subnet default sits clear of the Multus /23
# (it must not overlap it); enabling SR-IOV or CNF wants a /21 VNet. See
# docs/multus-validation.md and docs/network-prereqs.md.
ENABLE_SRIOV=false
SUBNET_SRIOV_CIDR=10.20.7.0/24

# ---- Optional CNF / telco profile (default OFF) ----------------------
# Set CNF_PROFILE=true to additionally create three telco LAN subnets
# (OAM + AUSF-UDM + HSS-HLR), give each worker a dedicated NIC on each LAN with
# Accelerated Networking, and bump the worker SKU to D8s_v5. Leave false for the
# standard generic runbook. Placeholder CIDRs below — set to the values agreed
# with the CNF vendor. See docs/cnf-telco-profile.md.
CNF_PROFILE=false
SUBNET_OAM_CIDR=10.20.4.0/28
SUBNET_AUSFUDM_CIDR=10.20.5.0/26
SUBNET_HSSHLR_CIDR=10.20.6.0/26

# Subnets (in addition to worker) where the cluster route table should be
# attached. Default master,bootstrap,multus is the right choice for hub-spoke
# + firewall-egress topologies, which is the recommended enterprise setup
# (see docs/network-prereqs.md). Leave empty to restore the legacy behavior
# where only the worker subnet has the UDR attached (NAT gateway / direct
# internet on master subnets).
ATTACH_RT_EXTRA_SUBNETS=master,bootstrap,multus

MACHINE_NETWORK_CIDR=10.20.1.0/24
CLUSTER_NETWORK_CIDR=10.128.0.0/14
CLUSTER_NETWORK_HOST_PREFIX=23
SERVICE_NETWORK_CIDR=172.30.0.0/16

# VM sizes for the OpenShift cluster.
#   x86_64 defaults below match Red Hat-tested baseline for OCP on Azure UPI:
#     control plane:     8 vCPU / 32 GB  (Standard_D8s_v5)
#     worker:            4 vCPU / 16 GB  (Standard_D4s_v5)
#     SR-IOV demo worker: 8 vCPU / 32 GB (Standard_D8s_v5; needs 4 NIC slots + AN)
#   For arm64 set:  CONTROL_PLANE_VM_SIZE=Standard_D8ps_v5
#                   WORKER_VM_SIZE=Standard_D4ps_v5
#                   SRIOV_WORKER_VM_SIZE=Standard_D8ps_v5
# These flow into Terraform via scripts/render-tfvars.sh (run automatically
# by every `make network|image|bootstrap|control-plane|workers` target).
CONTROL_PLANE_VM_SIZE=Standard_D8s_v5
WORKER_VM_SIZE=Standard_D4s_v5
# Only used when ENABLE_SRIOV=true.
SRIOV_WORKER_VM_SIZE=Standard_D8s_v5
PUBLISH=Internal

# Red Hat pull secret (download from console.redhat.com once logged in
# with a Red Hat developer account - free). Architecture-neutral.
# See docs/pre-install-checklist.md rows 1-2.
PULL_SECRET_FILE=secrets/pull-secret.txt
SSH_PUBLIC_KEY_FILE=secrets/id_ed25519.pub

# ---- Day-2 lifecycle (cluster-shutdown / cluster-startup / etcd-backup) ----
# Azure subscription that owns the cluster VMs (workload subscription).
# Leave unset to use the currently logged-in `az` subscription.
CLUSTER_SUBSCRIPTION_ID=

# Where etcd backups and lifecycle artifacts are written.
BACKUP_DIR=backups

# Max minutes the shutdown/startup scripts will wait for cluster operations.
OPERATIONS_TIMEOUT_MIN=30

# VM naming pattern used by the Terraform stages 03/04/05.
# Adjust only if you renamed the VMs.
CONTROL_PLANE_VM_PREFIX=vm-master
WORKER_VM_PREFIX=vm-worker
SRIOV_WORKER_VM_NAME=vm-worker-sriov
BOOTSTRAP_VM_NAME=vm-bootstrap
