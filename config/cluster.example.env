# Copy to config/cluster.env and adjust for your environment.

CLUSTER_NAME=lab
BASE_DOMAIN=ocp.example.com
LOCATION=northeurope

# Cluster CPU architecture. Drives:
#   - OpenShift install-config "architecture" (amd64 vs arm64)
#   - RHCOS stream lookup (x86_64 vs aarch64)
#   - Azure Shared Image Gallery image (x64 vs Arm64)
#   - Uploader VM size + Ubuntu image SKU
#   - Default VM-size families below (D*s_v5 vs D*ps_v5)
# Allowed values: x86_64 (default, most Azure deployments) | arm64
# See CPU-ARCHITECTURE.md for the full mapping table and override knobs.
ARCHITECTURE=x86_64

DNS_RESOURCE_GROUP=rg-dns-public-example
NETWORK_RESOURCE_GROUP=rg-network-example
WORKLOAD_RESOURCE_GROUP=rg-ocp-lab
VIRTUAL_NETWORK=vnet-ocp-example

CONTROL_PLANE_SUBNET=snet-ocp-master
COMPUTE_SUBNET=snet-ocp-worker

MACHINE_NETWORK_CIDR=10.20.1.0/24
CLUSTER_NETWORK_CIDR=10.128.0.0/14
CLUSTER_NETWORK_HOST_PREFIX=23
SERVICE_NETWORK_CIDR=172.30.0.0/16

# VM sizes for the OpenShift cluster.
#   x86_64 defaults below match Red Hat-tested baseline for OCP on Azure UPI:
#     control plane:     8 vCPU / 32 GB  (Standard_D8s_v5)
#     worker:            4 vCPU / 16 GB  (Standard_D4s_v5)
#     SR-IOV demo worker: 8 vCPU / 32 GB (Standard_D8s_v5; needs 4 NIC slots + AN)
#   For arm64 set:  CONTROL_PLANE_VM_SIZE=Standard_D8ps_v5
#                   WORKER_VM_SIZE=Standard_D4ps_v5
#                   SRIOV_WORKER_VM_SIZE=Standard_D8ps_v5
# These flow into Terraform via scripts/render-tfvars.sh (run automatically
# by every `make network|image|bootstrap|control-plane|workers` target).
CONTROL_PLANE_VM_SIZE=Standard_D8s_v5
WORKER_VM_SIZE=Standard_D4s_v5
SRIOV_WORKER_VM_SIZE=Standard_D8s_v5
PUBLISH=Internal

PULL_SECRET_FILE=secrets/pull-secret.txt
SSH_PUBLIC_KEY_FILE=secrets/id_ed25519.pub

# ---- Day-2 lifecycle (cluster-shutdown / cluster-startup / etcd-backup) ----
# Azure subscription that owns the cluster VMs (workload subscription).
# Leave unset to use the currently logged-in `az` subscription.
CLUSTER_SUBSCRIPTION_ID=

# Where etcd backups and lifecycle artifacts are written.
BACKUP_DIR=backups

# Max minutes the shutdown/startup scripts will wait for cluster operations.
OPERATIONS_TIMEOUT_MIN=30

# VM naming pattern used by the Terraform stages 03/04/05.
# Adjust only if you renamed the VMs.
CONTROL_PLANE_VM_PREFIX=vm-master
WORKER_VM_PREFIX=vm-worker
SRIOV_WORKER_VM_NAME=vm-worker-sriov
BOOTSTRAP_VM_NAME=vm-bootstrap
