# CNF / telco profile preset.
#
# Append these to (or merge them into) your config/cluster.env to enable the
# optional CNF profile. They override the matching defaults in
# config/cluster.example.env. Bash sourcing applies later assignments last, so
# appending this block to an existing cluster.env works.
#
# Replace the placeholder CIDRs with the values agreed with the CNF vendor, then
# run `make tfvars` (scripts/render-tfvars-from-env.sh) and apply the stacks.
# Full walkthrough: docs/cnf-telco-profile.md.

# Turn on the three CNF LAN subnets + per-LAN worker NICs + Accelerated Networking.
CNF_PROFILE=true

# 4-NIC worker SKU (primary + OAM + AUSF-UDM + HSS-HLR). D8s_v5 = 4 NIC slots and
# is Accelerated-Networking capable. Use Standard_D8ps_v5 for arm64.
WORKER_VM_SIZE=Standard_D8s_v5

# CNF LAN CIDRs (PLACEHOLDERS — set to the values agreed with the CNF vendor).
SUBNET_OAM_CIDR=10.20.4.0/28
SUBNET_AUSFUDM_CIDR=10.20.5.0/26
SUBNET_HSSHLR_CIDR=10.20.6.0/26

# If the external LANs need firewall-routed egress, add their roles to the route
# table attach list (otherwise leave as-is):
# ATTACH_RT_EXTRA_SUBNETS=master,bootstrap,multus,ausfudm,hsshlr

# Keep the in-cluster image registry (the CNF profile needs ImageStreams), then
# run scripts/configure-image-registry-managed.sh after install.
AUTO_IMAGE_REGISTRY_REMOVED=false

# Optional persistent Linux bastion (Helm/Python/oc) for operating the CNFs and
# reaching internal LBs (e.g. the ZTS Envoy LB on TCP 8175/8099).
CREATE_LINUX_BASTION=true
