cluster_subscription_id = "00000000-0000-0000-0000-000000000000"
location                = "northeurope"
cluster_name            = "lab"
# vm_size and sriov_worker_vm_size are set by scripts/render-tfvars.sh as
# vm-size.auto.tfvars from config/cluster.env (WORKER_VM_SIZE and
# SRIOV_WORKER_VM_SIZE). *.auto.tfvars overrides this file in terraform
# precedence; edit cluster.env to change them.
replicas                = 2
sriov_worker_zone       = "1"
worker_ignition_path    = "../../install/worker.ign"
ssh_public_key_path     = "../../secrets/id_ed25519.pub"

tags = {
  project  = "ocp-lab"
  workload = "openshift-multus-poc"
  role     = "worker"
}
